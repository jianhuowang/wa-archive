{
  "name": "wa-archive",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare:content": "node scripts/prepare-content.mjs",
    "dev": "npm run prepare:content && cross-env ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "npm run prepare:content && cross-env ASTRO_TELEMETRY_DISABLED=1 astro build",
