---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const { title, description, date, tags, category, difficulty, platform, status } = post.data;
---
<BaseLayout title={title} description={description}>
  <article class="article">
    <header class="article-header">
      <div class="eyebrow">{category}</div>
      <h1>{title}</h1>
      <p class="article-description">{description}</p>
      <div class="post-meta">
        <time datetime={date.toISOString()}>{date.toLocaleDateString('zh-CN')}</time>
        <span>·</span><span>WHJ</span>
      </div>
      {(platform || difficulty || status) && <div class="problem-facts">
        {platform && <span class="fact">平台：{platform}</span>}
        {difficulty && <span class="fact">难度：{difficulty}</span>}
        {status && <span class="fact">状态：{status}</span>}
      </div>}
      <div class="tag-list" style="margin-top: 1rem">
        {tags.map((tag) => <a class="tag" href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`}>#{tag}</a>)}
      </div>
    </header>
    <div class="prose"><slot /></div>
  </article>
</BaseLayout>
