---
import type { CollectionEntry } from 'astro:content';
interface Props { post: CollectionEntry<'blog'>; compact?: boolean; }
const { post } = Astro.props;
const { title, description, date, tags, category } = post.data;
const href = `${import.meta.env.BASE_URL}blog/${post.id}/`;
---
<article class="post-card">
  <div class="post-meta"><time datetime={date.toISOString()}>{date.toLocaleDateString('zh-CN')}</time><span>{category}</span></div>
  <div>
    <h2><a href={href}>{title}</a></h2>
    <p>{description}</p>
    <div class="tag-list">{tags.map((tag) => <span class="tag">#{tag}</span>)}</div>
  </div>
</article>
