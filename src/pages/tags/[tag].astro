---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap(({ data }) => data.tags))];
  return tags.map((tag) => ({ params: { tag }, props: { tag, posts: posts.filter(({ data }) => data.tags.includes(tag)) } }));
}
const { tag, posts } = Astro.props;
---
<BaseLayout title={`#${tag}`}>
  <header class="page-head container"><div class="eyebrow">Tagged entries</div><h1>#{tag}</h1><p>共 {posts.length} 篇归档。</p></header>
  <section class="post-list container">{posts.map((post) => <PostCard post={post} compact />)}</section>
</BaseLayout>
